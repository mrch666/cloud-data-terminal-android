<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Разрешаем резервное копирование в облако -->
        <include domain="database" path="cloud_terminal.db" />
        <include domain="sharedpref" path="." />
        <include domain="file" path="exports/" />
        <include domain="file" path="imports/" />
        
        <!-- Исключаем чувствительные данные -->
        <exclude domain="sharedpref" path="api_keys.xml" />
        <exclude domain="sharedpref" path="user_credentials.xml" />
    </cloud-backup>
    
    <device-transfer>
        <!-- Разрешаем передачу данных между устройствами -->
        <include domain="database" path="cloud_terminal.db" />
        <include domain="sharedpref" path="." />
        <include domain="file" path="exports/" />
        <include domain="file" path="imports/" />
        
        <!-- Исключаем временные файлы -->
        <exclude domain="file" path="cache/" />
        <exclude domain="file" path="temp/" />
    </device-transfer>
</data-extraction-rules>