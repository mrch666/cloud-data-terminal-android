<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.CloudTerminal" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/navigation_bar</item>
        
        <!-- Surface colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/background_dark</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        
        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        
        <!-- Typography -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.CloudTerminal.Headline.Large</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.CloudTerminal.Headline.Medium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.CloudTerminal.Headline.Small</item>
        
        <item name="textAppearanceTitleLarge">@style/TextAppearance.CloudTerminal.Title.Large</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.CloudTerminal.Title.Medium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.CloudTerminal.Title.Small</item>
        
        <item name="textAppearanceBodyLarge">@style/TextAppearance.CloudTerminal.Body.Large</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.CloudTerminal.Body.Medium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.CloudTerminal.Body.Small</item>
        
        <item name="textAppearanceLabelLarge">@style/TextAppearance.CloudTerminal.Label.Large</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.CloudTerminal.Label.Medium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.CloudTerminal.Label.Small</item>
        
        <!-- Button styles -->
        <item name="materialButtonStyle">@style/Widget.CloudTerminal.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.CloudTerminal.Button.Outlined</item>
        <item name="materialButtonToggleGroupStyle">@style/Widget.CloudTerminal.ButtonToggleGroup</item>
        
        <!-- Card styles -->
        <item name="materialCardViewStyle">@style/Widget.CloudTerminal.CardView</item>
        
        <!-- Shape appearance -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.CloudTerminal.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CloudTerminal.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.CloudTerminal.Large</item>
        
        <!-- Elevation -->
        <item name="elevationSmall">4dp</item>
        <item name="elevationMedium">8dp</item>
        <item name="elevationLarge">16dp</item>
        
        <!-- Corner radius -->
        <item name="cornerRadiusSmall">4dp</item>
        <item name="cornerRadiusMedium">8dp</item>
        <item name="cornerRadiusLarge">16dp</item>
        
        <!-- Animation -->
        <item name="android:animationDurationShort">200</item>
        <item name="android:animationDurationMedium">300</item>
        <item name="android:animationDurationLong">400</item>
    </style>
    
    <!-- Dark theme -->
    <style name="Theme.CloudTerminal.Dark" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_light</item>
        <item name="colorOnPrimary">@color/black</item>
        
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <item name="android:statusBarColor">@color/status_bar_dark</item>
        <item name="android:navigationBarColor">@color/navigation_bar_dark</item>
        
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/text_secondary</item>
        
        <item name="android:colorBackground">@color/black</item>
    </style>
    
    <!-- Typography styles -->
    <style name="TextAppearance.CloudTerminal.Headline.Large" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Headline.Medium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Headline.Small" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Title.Large" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Title.Medium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Title.Small" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Body.Large" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Body.Medium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Body.Small" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Label.Large" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Label.Medium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.CloudTerminal.Label.Small" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Button styles -->
    <style name="Widget.CloudTerminal.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">@dimen/corner_radius_medium</item>
        <item name="android:textAppearance">@style/TextAppearance.CloudTerminal.Label.Large</item>
    </style>
    
    <style name="Widget.CloudTerminal.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">@dimen/corner_radius_medium</item>
        <item name="android:textAppearance">@style/TextAppearance.CloudTerminal.Label.Large</item>
    </style>
    
    <style name="Widget.CloudTerminal.ButtonToggleGroup" parent="Widget.Material3.ButtonToggleGroup">
        <item name="singleSelection">true</item>
        <item name="checkedButton">@null</item>
    </style>
    
    <!-- Card styles -->
    <style name="Widget.CloudTerminal.CardView" parent="Widget.Material3.CardView">
        <item name="cardCornerRadius">@dimen/corner_radius_medium</item>
        <item name="cardElevation">@dimen/elevation_small</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>
    
    <!-- Shape appearance -->
    <style name="ShapeAppearance.CloudTerminal.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>
    
    <style name="ShapeAppearance.CloudTerminal.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearance.CloudTerminal.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <!-- Dialog theme -->
    <style name="Theme.CloudTerminal.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/Animation.CloudTerminal.Dialog</item>
    </style>
    
    <!-- Animation styles -->
    <style name="Animation.CloudTerminal.Dialog" parent="Animation.AppCompat.Dialog">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>
    
    <!-- Progress bar style -->
    <style name="Widget.CloudTerminal.ProgressBar" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/progress_foreground</item>
        <item name="trackColor">@color/progress_background</item>
        <item name="strokeWidth">4dp</item>
    </style>
    
    <!-- Chip styles -->
    <style name="Widget.CloudTerminal.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">@dimen/corner_radius_large</item>
        <item name="chipBackgroundColor">@color/primary_light</item>
        <item name="chipStrokeColor">@color/primary</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>
    
    <!-- Text field styles -->
    <style name="Widget.CloudTerminal.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_medium</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_medium</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_radius_medium</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_radius_medium</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">1dp</item>
    </style>
